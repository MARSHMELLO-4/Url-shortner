<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body{
            font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif
        }
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>
        Url Shortner
    </h1>
    <div>
        <form method="POST" action="/url">
            <label for="urlField">Enter Your Original Url</label>
            <input type="text" name="url" id="urlField" placeholder="https://example.com">
            <button>
                Generate
            </button>
        </form>
        <% if (locals.id) { %>
    <!-- HTML to render if condition is true -->
            <p> Url generated : http://localhost:8001/<%= id %>   </p>
        <% } %>
        <h2>All URLs</h2>
        <table border="1" cellpadding="10" cellspacing="0">
            <thead>
                <tr>
                    <th>Original URL</th>
                    <th>Short URL</th>
                </tr>
            </thead>
            <tbody>
                <% if (locals.urls && locals.urls.length > 0) { %>
                    <% locals.urls.forEach(url => { %>
                        <tr>
                            <td><%= url.redirectUrl %></td>
                            <td><a href="http://localhost:8001/<%= url.shortId %>">http://localhost:8001/<%= url.shortId %></a></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="2">No URLs yet</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html> 